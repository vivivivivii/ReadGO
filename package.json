{
  "name": "readgo",
  "version": "1.0.0",
  "description": "ReadGO · 个人藏书与 DeepSeek 智能导书",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0 <=22.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "push:github": "node scripts/github-push.mjs",
    "preview": "npm run build && npm start"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.8.1",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^2.0.2",
    "vite": "^5.4.8",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
